<svg xmlns="http://www.w3.org/2000/svg" width="800" height="400" viewBox="0 0 800 400">
  <defs>
    <linearGradient id="mapGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#74b9ff;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#0984e3;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Fondo -->
  <rect width="800" height="400" fill="url(#mapGradient)"/>
  
  <!-- Mapa base de Lima -->
  <g transform="translate(100, 50)">
    <!-- Contorno de Lima -->
    <path d="M 50 50 Q 150 30 250 50 Q 350 70 400 120 Q 420 180 400 240 Q 350 280 250 290 Q 150 300 50 280 Q 20 220 30 160 Q 40 100 50 50 Z" 
          fill="#2d3436" opacity="0.8" stroke="#FFFFFF" stroke-width="2"/>
    
    <!-- Océano Pacífico -->
    <rect x="-50" y="0" width="50" height="350" fill="#74b9ff" opacity="0.6"/>
    <text x="-25" y="175" text-anchor="middle" font-family="Arial, sans-serif" font-size="12" fill="#FFFFFF" transform="rotate(-90, -25, 175)">OCÉANO PACÍFICO</text>
  </g>
  
  <!-- Ubicaciones estratégicas -->
  <g>
    <!-- Chancay -->
    <g transform="translate(200, 80)">
      <circle cx="0" cy="0" r="8" fill="#e17055"/>
      <circle cx="0" cy="0" r="15" fill="none" stroke="#e17055" stroke-width="2" opacity="0.5">
        <animate attributeName="r" values="15;25;15" dur="2s" repeatCount="indefinite"/>
        <animate attributeName="opacity" values="0.5;0;0.5" dur="2s" repeatCount="indefinite"/>
      </circle>
      <text x="0" y="-25" text-anchor="middle" font-family="Arial, sans-serif" font-size="11" fill="#FFFFFF" font-weight="bold">CHANCAY</text>
      <text x="0" y="-12" text-anchor="middle" font-family="Arial, sans-serif" font-size="8" fill="#FFFFFF">Puerto + Desarrollo</text>
    </g>
    
    <!-- Lurín -->
    <g transform="translate(300, 280)">
      <circle cx="0" cy="0" r="8" fill="#00b894"/>
      <circle cx="0" cy="0" r="15" fill="none" stroke="#00b894" stroke-width="2" opacity="0.5">
        <animate attributeName="r" values="15;25;15" dur="2.5s" repeatCount="indefinite"/>
        <animate attributeName="opacity" values="0.5;0;0.5" dur="2.5s" repeatCount="indefinite"/>
      </circle>
      <text x="0" y="-25" text-anchor="middle" font-family="Arial, sans-serif" font-size="11" fill="#FFFFFF" font-weight="bold">LURÍN</text>
      <text x="0" y="-12" text-anchor="middle" font-family="Arial, sans-serif" font-size="8" fill="#FFFFFF">Expansión Sur</text>
    </g>
    
    <!-- Pachacámac -->
    <g transform="translate(350, 250)">
      <circle cx="0" cy="0" r="8" fill="#fdcb6e"/>
      <circle cx="0" cy="0" r="15" fill="none" stroke="#fdcb6e" stroke-width="2" opacity="0.5">
        <animate attributeName="r" values="15;25;15" dur="3s" repeatCount="indefinite"/>
        <animate attributeName="opacity" values="0.5;0;0.5" dur="3s" repeatCount="indefinite"/>
      </circle>
      <text x="0" y="-25" text-anchor="middle" font-family="Arial, sans-serif" font-size="11" fill="#FFFFFF" font-weight="bold">PACHACÁMAC</text>
      <text x="0" y="-12" text-anchor="middle" font-family="Arial, sans-serif" font-size="8" fill="#FFFFFF">Residencial</text>
    </g>
    
    <!-- Santa Rosa -->
    <g transform="translate(150, 120)">
      <circle cx="0" cy="0" r="8" fill="#6c5ce7"/>
      <circle cx="0" cy="0" r="15" fill="none" stroke="#6c5ce7" stroke-width="2" opacity="0.5">
        <animate attributeName="r" values="15;25;15" dur="2.2s" repeatCount="indefinite"/>
        <animate attributeName="opacity" values="0.5;0;0.5" dur="2.2s" repeatCount="indefinite"/>
      </circle>
      <text x="0" y="-25" text-anchor="middle" font-family="Arial, sans-serif" font-size="11" fill="#FFFFFF" font-weight="bold">SANTA ROSA</text>
      <text x="0" y="-12" text-anchor="middle" font-family="Arial, sans-serif" font-size="8" fill="#FFFFFF">Costa Norte</text>
    </g>
    
    <!-- Lima Centro -->
    <g transform="translate(250, 180)">
      <circle cx="0" cy="0" r="10" fill="#fd79a8"/>
      <text x="0" y="-20" text-anchor="middle" font-family="Arial, sans-serif" font-size="11" fill="#FFFFFF" font-weight="bold">LIMA CENTRO</text>
    </g>
  </g>
  
  <!-- Vías principales -->
  <g stroke="#FFFFFF" stroke-width="3" fill="none" opacity="0.7">
    <!-- Panamericana Norte -->
    <path d="M 200 80 Q 220 120 250 180"/>
    <text x="180" y="130" font-family="Arial, sans-serif" font-size="9" fill="#FFFFFF" transform="rotate(-45, 180, 130)">Panamericana Norte</text>
    
    <!-- Panamericana Sur -->
    <path d="M 250 180 Q 280 220 300 280"/>
    <text x="320" y="230" font-family="Arial, sans-serif" font-size="9" fill="#FFFFFF" transform="rotate(45, 320, 230)">Panamericana Sur</text>
    
    <!-- Carretera Central -->
    <path d="M 250 180 L 400 180"/>
    <text x="325" y="175" font-family="Arial, sans-serif" font-size="9" fill="#FFFFFF">Carretera Central</text>
  </g>
  
  <!-- Información de ubicaciones -->
  <g transform="translate(500, 100)">
    <rect x="0" y="0" width="250" height="200" fill="#2d3436" opacity="0.9" rx="10"/>
    
    <text x="125" y="25" text-anchor="middle" font-family="Arial, sans-serif" font-size="16" fill="#FFFFFF" font-weight="bold">UBICACIONES PREMIUM</text>
    
    <!-- Lista de ubicaciones -->
    <g font-family="Arial, sans-serif" font-size="11" fill="#FFFFFF">
      <g transform="translate(20, 50)">
        <circle cx="0" cy="0" r="4" fill="#e17055"/>
        <text x="15" y="4" font-weight="bold">Chancay</text>
        <text x="15" y="16" font-size="9" opacity="0.8">Puerto + Logística</text>
      </g>
      
      <g transform="translate(20, 80)">
        <circle cx="0" cy="0" r="4" fill="#00b894"/>
        <text x="15" y="4" font-weight="bold">Lurín</text>
        <text x="15" y="16" font-size="9" opacity="0.8">Crecimiento 15% anual</text>
      </g>
      
      <g transform="translate(20, 110)">
        <circle cx="0" cy="0" r="4" fill="#fdcb6e"/>
        <text x="15" y="4" font-weight="bold">Pachacámac</text>
        <text x="15" y="16" font-size="9" opacity="0.8">Zona residencial</text>
      </g>
      
      <g transform="translate(20, 140)">
        <circle cx="0" cy="0" r="4" fill="#6c5ce7"/>
        <text x="15" y="4" font-weight="bold">Santa Rosa</text>
        <text x="15" y="16" font-size="9" opacity="0.8">Acceso a playas</text>
      </g>
    </g>
    
    <!-- Factores clave -->
    <text x="20" y="175" font-family="Arial, sans-serif" font-size="10" fill="#74b9ff" font-weight="bold">✓ Conectividad</text>
    <text x="120" y="175" font-family="Arial, sans-serif" font-size="10" fill="#74b9ff" font-weight="bold">✓ Servicios</text>
    <text x="20" y="190" font-family="Arial, sans-serif" font-size="10" fill="#74b9ff" font-weight="bold">✓ Crecimiento</text>
    <text x="120" y="190" font-family="Arial, sans-serif" font-size="10" fill="#74b9ff" font-weight="bold">✓ Valorización</text>
  </g>
  
  <!-- Título principal -->
  <text x="400" y="30" text-anchor="middle" font-family="Arial, sans-serif" font-size="28" font-weight="bold" fill="#FFFFFF">
    Ubicaciones Estratégicas
  </text>
  
  <!-- Subtítulo -->
  <text x="400" y="380" text-anchor="middle" font-family="Arial, sans-serif" font-size="14" fill="#FFFFFF">
    Las mejores zonas para tu inversión inmobiliaria
  </text>
</svg>