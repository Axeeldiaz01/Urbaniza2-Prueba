<svg xmlns="http://www.w3.org/2000/svg" width="800" height="400" viewBox="0 0 800 400">
  <defs>
    <linearGradient id="financeGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#667eea;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#764ba2;stop-opacity:1" />
    </linearGradient>
    <linearGradient id="cardGradient" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" style="stop-color:#ff7b7b;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#667eea;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Fondo -->
  <rect width="800" height="400" fill="url(#financeGradient)"/>
  
  <!-- Tarjeta de crédito principal -->
  <g transform="translate(50, 80)">
    <rect x="0" y="0" width="300" height="180" fill="url(#cardGradient)" rx="15"/>
    <rect x="20" y="20" width="260" height="30" fill="#FFFFFF" opacity="0.2" rx="5"/>
    
    <!-- Chip -->
    <rect x="30" y="70" width="40" height="30" fill="#f39c12" rx="5"/>
    <rect x="35" y="75" width="30" height="20" fill="#e67e22" rx="3"/>
    
    <!-- Números de tarjeta -->
    <text x="90" y="95" font-family="Courier, monospace" font-size="18" fill="#FFFFFF" font-weight="bold">
      **** **** **** 1234
    </text>
    
    <!-- Nombre -->
    <text x="30" y="130" font-family="Arial, sans-serif" font-size="12" fill="#FFFFFF">
      CRÉDITO HIPOTECARIO
    </text>
    
    <!-- Fecha -->
    <text x="30" y="150" font-family="Arial, sans-serif" font-size="10" fill="#FFFFFF">
      VÁLIDO HASTA 12/28
    </text>
    
    <!-- Logo del banco -->
    <circle cx="250" cy="40" r="20" fill="#FFFFFF" opacity="0.8"/>
    <text x="250" y="45" text-anchor="middle" font-family="Arial, sans-serif" font-size="12" fill="#667eea" font-weight="bold">BANCO</text>
  </g>
  
  <!-- Calculadora -->
  <g transform="translate(450, 100)">
    <rect x="0" y="0" width="120" height="160" fill="#2c3e50" rx="10"/>
    
    <!-- Pantalla -->
    <rect x="10" y="10" width="100" height="30" fill="#27ae60" rx="3"/>
    <text x="60" y="28" text-anchor="middle" font-family="Arial, sans-serif" font-size="12" fill="#FFFFFF">S/ 250,000</text>
    
    <!-- Botones -->
    <g fill="#34495e">
      <rect x="15" y="50" width="20" height="20" rx="3"/>
      <rect x="40" y="50" width="20" height="20" rx="3"/>
      <rect x="65" y="50" width="20" height="20" rx="3"/>
      <rect x="90" y="50" width="20" height="20" rx="3"/>
      
      <rect x="15" y="75" width="20" height="20" rx="3"/>
      <rect x="40" y="75" width="20" height="20" rx="3"/>
      <rect x="65" y="75" width="20" height="20" rx="3"/>
      <rect x="90" y="75" width="20" height="20" rx="3"/>
      
      <rect x="15" y="100" width="20" height="20" rx="3"/>
      <rect x="40" y="100" width="20" height="20" rx="3"/>
      <rect x="65" y="100" width="20" height="20" rx="3"/>
      <rect x="90" y="100" width="20" height="20" rx="3"/>
      
      <rect x="15" y="125" width="45" height="20" rx="3"/>
      <rect x="65" y="125" width="45" height="20" rx="3"/>
    </g>
    
    <!-- Números en botones -->
    <g font-family="Arial, sans-serif" font-size="10" fill="#FFFFFF" text-anchor="middle">
      <text x="25" y="63">7</text>
      <text x="50" y="63">8</text>
      <text x="75" y="63">9</text>
      <text x="100" y="63">÷</text>
      
      <text x="25" y="88">4</text>
      <text x="50" y="88">5</text>
      <text x="75" y="88">6</text>
      <text x="100" y="88">×</text>
      
      <text x="25" y="113">1</text>
      <text x="50" y="113">2</text>
      <text x="75" y="113">3</text>
      <text x="100" y="113">-</text>
      
      <text x="37" y="138">0</text>
      <text x="87" y="138">=</text>
    </g>
  </g>
  
  <!-- Casa -->
  <g transform="translate(600, 150)">
    <!-- Base de la casa -->
    <rect x="0" y="50" width="120" height="80" fill="#e74c3c"/>
    
    <!-- Techo -->
    <path d="M -10 50 L 60 10 L 130 50 Z" fill="#c0392b"/>
    
    <!-- Puerta -->
    <rect x="45" y="90" width="30" height="40" fill="#8b4513"/>
    <circle cx="70" cy="110" r="2" fill="#f39c12"/>
    
    <!-- Ventanas -->
    <rect x="15" y="70" width="20" height="15" fill="#3498db"/>
    <rect x="85" y="70" width="20" height="15" fill="#3498db"/>
    
    <!-- Cruz en ventanas -->
    <line x1="25" y1="70" x2="25" y2="85" stroke="#2c3e50" stroke-width="1"/>
    <line x1="15" y1="77" x2="35" y2="77" stroke="#2c3e50" stroke-width="1"/>
    <line x1="95" y1="70" x2="95" y2="85" stroke="#2c3e50" stroke-width="1"/>
    <line x1="85" y1="77" x2="105" y2="77" stroke="#2c3e50" stroke-width="1"/>
  </g>
  
  <!-- Iconos de opciones de financiamiento -->
  <g>
    <!-- Banco -->
    <g transform="translate(100, 300)">
      <rect x="-30" y="-15" width="60" height="30" fill="#34495e" rx="5"/>
      <rect x="-25" y="-10" width="10" height="20" fill="#ecf0f1"/>
      <rect x="-10" y="-10" width="10" height="20" fill="#ecf0f1"/>
      <rect x="5" y="-10" width="10" height="20" fill="#ecf0f1"/>
      <rect x="20" y="-10" width="10" height="20" fill="#ecf0f1"/>
      <rect x="-35" y="15" width="70" height="5" fill="#2c3e50"/>
      <text x="0" y="35" text-anchor="middle" font-family="Arial, sans-serif" font-size="10" fill="#FFFFFF">Banco</text>
    </g>
    
    <!-- Cooperativa -->
    <g transform="translate(300, 300)">
      <circle cx="0" cy="0" r="20" fill="#27ae60"/>
      <path d="M -8 -8 L 8 -8 L 8 8 L -8 8 Z" fill="#FFFFFF"/>
      <path d="M -4 -4 L 4 -4 L 4 4 L -4 4 Z" fill="#27ae60"/>
      <text x="0" y="35" text-anchor="middle" font-family="Arial, sans-serif" font-size="10" fill="#FFFFFF">Cooperativa</text>
    </g>
    
    <!-- Financiera -->
    <g transform="translate(500, 300)">
      <rect x="-20" y="-15" width="40" height="30" fill="#e67e22" rx="5"/>
      <text x="0" y="-2" text-anchor="middle" font-family="Arial, sans-serif" font-size="12" fill="#FFFFFF" font-weight="bold">$</text>
      <text x="0" y="35" text-anchor="middle" font-family="Arial, sans-serif" font-size="10" fill="#FFFFFF">Financiera</text>
    </g>
    
    <!-- Leasing -->
    <g transform="translate(700, 300)">
      <rect x="-20" y="-15" width="40" height="30" fill="#9b59b6" rx="5"/>
      <path d="M -10 -5 L 10 -5 L 5 5 L -5 5 Z" fill="#FFFFFF"/>
      <text x="0" y="35" text-anchor="middle" font-family="Arial, sans-serif" font-size="10" fill="#FFFFFF">Leasing</text>
    </g>
  </g>
  
  <!-- Texto principal -->
  <text x="400" y="40" text-anchor="middle" font-family="Arial, sans-serif" font-size="28" font-weight="bold" fill="#FFFFFF">
    Opciones de Financiamiento
  </text>
  
  <!-- Información de tasas -->
  <g font-family="Arial, sans-serif" font-size="12" fill="#FFFFFF">
    <text x="400" y="370" text-anchor="middle">Tasas desde 8.5% • Hasta 30 años • Inicial desde 10%</text>
  </g>
  
  <!-- Flecha conectora -->
  <path d="M 370 180 Q 400 160 430 180" stroke="#f39c12" stroke-width="3" fill="none" marker-end="url(#arrowhead)"/>
  
  <defs>
    <marker id="arrowhead" markerWidth="10" markerHeight="7" refX="9" refY="3.5" orient="auto">
      <polygon points="0 0, 10 3.5, 0 7" fill="#f39c12"/>
    </marker>
  </defs>
</svg>