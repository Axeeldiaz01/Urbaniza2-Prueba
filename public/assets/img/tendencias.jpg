<svg xmlns="http://www.w3.org/2000/svg" width="800" height="400" viewBox="0 0 800 400">
  <defs>
    <linearGradient id="bgGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#667eea;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#764ba2;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Fondo -->
  <rect width="800" height="400" fill="url(#bgGradient)"/>
  
  <!-- Gráfico de tendencias -->
  <g stroke="#FFFFFF" stroke-width="3" fill="none">
    <!-- Ejes -->
    <line x1="100" y1="350" x2="700" y2="350"/>
    <line x1="100" y1="350" x2="100" y2="50"/>
    
    <!-- Línea de tendencia ascendente -->
    <polyline points="100,320 200,280 300,240 400,200 500,160 600,120 700,80" stroke="#00FF88" stroke-width="4"/>
    
    <!-- Puntos de datos -->
    <circle cx="200" cy="280" r="6" fill="#00FF88"/>
    <circle cx="300" cy="240" r="6" fill="#00FF88"/>
    <circle cx="400" cy="200" r="6" fill="#00FF88"/>
    <circle cx="500" cy="160" r="6" fill="#00FF88"/>
    <circle cx="600" cy="120" r="6" fill="#00FF88"/>
  </g>
  
  <!-- Edificios modernos -->
  <g fill="#FFFFFF" opacity="0.3">
    <rect x="150" y="250" width="40" height="100"/>
    <rect x="200" y="200" width="35" height="150"/>
    <rect x="250" y="180" width="45" height="170"/>
    <rect x="300" y="160" width="40" height="190"/>
    <rect x="350" y="140" width="50" height="210"/>
  </g>
  
  <!-- Iconos de tendencias -->
  <g fill="#FFD700">
    <!-- Icono de casa inteligente -->
    <rect x="450" y="100" width="30" height="25" stroke="#FFD700" stroke-width="2" fill="none"/>
    <polygon points="450,100 465,85 480,100" fill="#FFD700"/>
    <circle cx="460" cy="110" r="3" fill="#FFD700"/>
    
    <!-- Icono de sostenibilidad -->
    <circle cx="550" cy="110" r="15" fill="none" stroke="#00FF88" stroke-width="3"/>
    <path d="M 545 110 Q 550 100 555 110 Q 550 120 545 110" fill="#00FF88"/>
    
    <!-- Icono de tecnología -->
    <rect x="620" y="95" width="25" height="15" fill="#00BFFF" rx="3"/>
    <rect x="625" y="100" width="15" height="8" fill="#000000"/>
  </g>
  
  <!-- Texto principal -->
  <text x="400" y="40" text-anchor="middle" font-family="Arial, sans-serif" font-size="28" font-weight="bold" fill="#FFFFFF">
    Tendencias del Mercado 2025
  </text>
  
  <!-- Etiquetas de años -->
  <g font-family="Arial, sans-serif" font-size="14" fill="#FFFFFF">
    <text x="200" y="370" text-anchor="middle">2021</text>
    <text x="300" y="370" text-anchor="middle">2022</text>
    <text x="400" y="370" text-anchor="middle">2023</text>
    <text x="500" y="370" text-anchor="middle">2024</text>
    <text x="600" y="370" text-anchor="middle">2025</text>
  </g>
  
  <!-- Porcentajes -->
  <g font-family="Arial, sans-serif" font-size="12" fill="#FFFFFF">
    <text x="90" y="320" text-anchor="end">+5%</text>
    <text x="90" y="280" text-anchor="end">+10%</text>
    <text x="90" y="240" text-anchor="end">+15%</text>
    <text x="90" y="200" text-anchor="end">+20%</text>
    <text x="90" y="160" text-anchor="end">+25%</text>
    <text x="90" y="120" text-anchor="end">+30%</text>
  </g>
</svg>