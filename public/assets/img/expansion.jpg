<svg xmlns="http://www.w3.org/2000/svg" width="800" height="400" viewBox="0 0 800 400">
  <defs>
    <linearGradient id="expansionGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#4facfe;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#00f2fe;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Fondo -->
  <rect width="800" height="400" fill="url(#expansionGradient)"/>
  
  <!-- Ciudad central -->
  <g transform="translate(300, 150)">
    <!-- Edificios del centro -->
    <rect x="0" y="50" width="40" height="100" fill="#2c3e50"/>
    <rect x="50" y="30" width="45" height="120" fill="#34495e"/>
    <rect x="105" y="40" width="35" height="110" fill="#2c3e50"/>
    <rect x="150" y="20" width="50" height="130" fill="#34495e"/>
    
    <!-- Ventanas -->
    <g fill="#f39c12">
      <rect x="10" y="70" width="6" height="8"/>
      <rect x="20" y="70" width="6" height="8"/>
      <rect x="10" y="90" width="6" height="8"/>
      <rect x="20" y="90" width="6" height="8"/>
      
      <rect x="60" y="50" width="6" height="8"/>
      <rect x="70" y="50" width="6" height="8"/>
      <rect x="80" y="50" width="6" height="8"/>
      
      <rect x="115" y="60" width="6" height="8"/>
      <rect x="125" y="60" width="6" height="8"/>
      
      <rect x="160" y="40" width="6" height="8"/>
      <rect x="170" y="40" width="6" height="8"/>
      <rect x="180" y="40" width="6" height="8"/>
    </g>
  </g>
  
  <!-- Flechas de expansión -->
  <g stroke="#e74c3c" stroke-width="4" fill="#e74c3c">
    <!-- Flecha hacia arriba -->
    <path d="M 400 120 L 400 80 M 390 90 L 400 80 L 410 90"/>
    
    <!-- Flecha hacia la derecha -->
    <path d="M 520 200 L 580 200 M 570 190 L 580 200 L 570 210"/>
    
    <!-- Flecha hacia abajo -->
    <path d="M 400 280 L 400 320 M 390 310 L 400 320 L 410 310"/>
    
    <!-- Flecha hacia la izquierda -->
    <path d="M 280 200 L 220 200 M 230 190 L 220 200 L 230 210"/>
  </g>
  
  <!-- Nuevas zonas de desarrollo -->
  <g>
    <!-- Zona Norte -->
    <g transform="translate(350, 50)">
      <rect x="0" y="0" width="100" height="40" fill="#27ae60" opacity="0.7" rx="5"/>
      <text x="50" y="25" text-anchor="middle" font-family="Arial, sans-serif" font-size="12" fill="#FFFFFF" font-weight="bold">ZONA NORTE</text>
    </g>
    
    <!-- Zona Este -->
    <g transform="translate(600, 180)">
      <rect x="0" y="0" width="100" height="40" fill="#e67e22" opacity="0.7" rx="5"/>
      <text x="50" y="25" text-anchor="middle" font-family="Arial, sans-serif" font-size="12" fill="#FFFFFF" font-weight="bold">ZONA ESTE</text>
    </g>
    
    <!-- Zona Sur -->
    <g transform="translate(350, 330)">
      <rect x="0" y="0" width="100" height="40" fill="#9b59b6" opacity="0.7" rx="5"/>
      <text x="50" y="25" text-anchor="middle" font-family="Arial, sans-serif" font-size="12" fill="#FFFFFF" font-weight="bold">ZONA SUR</text>
    </g>
    
    <!-- Zona Oeste -->
    <g transform="translate(100, 180)">
      <rect x="0" y="0" width="100" height="40" fill="#3498db" opacity="0.7" rx="5"/>
      <text x="50" y="25" text-anchor="middle" font-family="Arial, sans-serif" font-size="12" fill="#FFFFFF" font-weight="bold">ZONA OESTE</text>
    </g>
  </g>
  
  <!-- Nuevos desarrollos -->
  <g>
    <!-- Casas en zona norte -->
    <g transform="translate(370, 20)">
      <rect x="0" y="0" width="15" height="12" fill="#e74c3c"/>
      <path d="M -2 0 L 7.5 -8 L 17 0 Z" fill="#c0392b"/>
      
      <rect x="20" y="0" width="15" height="12" fill="#e74c3c"/>
      <path d="M 18 0 L 27.5 -8 L 37 0 Z" fill="#c0392b"/>
      
      <rect x="40" y="0" width="15" height="12" fill="#e74c3c"/>
      <path d="M 38 0 L 47.5 -8 L 57 0 Z" fill="#c0392b"/>
    </g>
    
    <!-- Edificios en zona este -->
    <g transform="translate(620, 150)">
      <rect x="0" y="0" width="12" height="25" fill="#34495e"/>
      <rect x="15" y="0" width="12" height="20" fill="#2c3e50"/>
      <rect x="30" y="0" width="12" height="30" fill="#34495e"/>
      <rect x="45" y="0" width="12" height="22" fill="#2c3e50"/>
    </g>
    
    <!-- Casas en zona sur -->
    <g transform="translate(370, 300)">
      <rect x="0" y="0" width="15" height="12" fill="#e74c3c"/>
      <path d="M -2 0 L 7.5 -8 L 17 0 Z" fill="#c0392b"/>
      
      <rect x="20" y="0" width="15" height="12" fill="#e74c3c"/>
      <path d="M 18 0 L 27.5 -8 L 37 0 Z" fill="#c0392b"/>
      
      <rect x="40" y="0" width="15" height="12" fill="#e74c3c"/>
      <path d="M 38 0 L 47.5 -8 L 57 0 Z" fill="#c0392b"/>
    </g>
    
    <!-- Comercios en zona oeste -->
    <g transform="translate(120, 150)">
      <rect x="0" y="0" width="20" height="15" fill="#f39c12"/>
      <rect x="25" y="0" width="20" height="15" fill="#e67e22"/>
      <rect x="50" y="0" width="20" height="15" fill="#f39c12"/>
    </g>
  </g>
  
  <!-- Carreteras de conexión -->
  <g stroke="#7f8c8d" stroke-width="3" fill="none">
    <path d="M 400 150 L 400 100"/>
    <path d="M 500 200 L 600 200"/>
    <path d="M 400 250 L 400 300"/>
    <path d="M 300 200 L 200 200"/>
  </g>
  
  <!-- Título -->
  <text x="400" y="30" text-anchor="middle" font-family="Arial, sans-serif" font-size="24" font-weight="bold" fill="#2c3e50">
    Expansión Territorial
  </text>
  
  <!-- Indicadores de crecimiento -->
  <g font-family="Arial, sans-serif" font-size="10" fill="#2c3e50">
    <text x="400" y="380" text-anchor="middle">Crecimiento Urbano • Nuevas Oportunidades • Desarrollo Planificado</text>
  </g>
</svg>