<svg xmlns="http://www.w3.org/2000/svg" width="800" height="400" viewBox="0 0 800 400">
  <defs>
    <linearGradient id="ecoGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#56ab2f;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#a8e6cf;stop-opacity:1" />
    </linearGradient>
    <radialGradient id="sunGradient" cx="50%" cy="50%" r="50%">
      <stop offset="0%" style="stop-color:#ffd89b;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#19547b;stop-opacity:0" />
    </radialGradient>
  </defs>
  
  <!-- Fondo -->
  <rect width="800" height="400" fill="url(#ecoGradient)"/>
  
  <!-- Sol -->
  <circle cx="650" cy="80" r="40" fill="url(#sunGradient)"/>
  
  <!-- Edificio sostenible -->
  <g>
    <!-- Estructura principal -->
    <rect x="300" y="150" width="200" height="200" fill="#2c3e50" rx="10"/>
    
    <!-- Paneles solares en el techo -->
    <rect x="310" y="140" width="180" height="20" fill="#34495e" rx="5"/>
    <g fill="#3498db">
      <rect x="315" y="145" width="25" height="10" rx="2"/>
      <rect x="345" y="145" width="25" height="10" rx="2"/>
      <rect x="375" y="145" width="25" height="10" rx="2"/>
      <rect x="405" y="145" width="25" height="10" rx="2"/>
      <rect x="435" y="145" width="25" height="10" rx="2"/>
      <rect x="465" y="145" width="25" height="10" rx="2"/>
    </g>
    
    <!-- Jardín vertical -->
    <rect x="290" y="160" width="15" height="180" fill="#27ae60"/>
    <g fill="#2ecc71">
      <circle cx="297" cy="170" r="3"/>
      <circle cx="297" cy="190" r="3"/>
      <circle cx="297" cy="210" r="3"/>
      <circle cx="297" cy="230" r="3"/>
      <circle cx="297" cy="250" r="3"/>
      <circle cx="297" cy="270" r="3"/>
      <circle cx="297" cy="290" r="3"/>
      <circle cx="297" cy="310" r="3"/>
      <circle cx="297" cy="330" r="3"/>
    </g>
    
    <!-- Ventanas eficientes -->
    <g fill="#ecf0f1">
      <rect x="320" y="180" width="30" height="40" rx="3"/>
      <rect x="360" y="180" width="30" height="40" rx="3"/>
      <rect x="400" y="180" width="30" height="40" rx="3"/>
      <rect x="450" y="180" width="30" height="40" rx="3"/>
      
      <rect x="320" y="240" width="30" height="40" rx="3"/>
      <rect x="360" y="240" width="30" height="40" rx="3"/>
      <rect x="400" y="240" width="30" height="40" rx="3"/>
      <rect x="450" y="240" width="30" height="40" rx="3"/>
    </g>
    
    <!-- Sistema de recolección de agua -->
    <rect x="510" y="160" width="20" height="180" fill="#3498db" opacity="0.7"/>
    <circle cx="520" cy="170" r="5" fill="#2980b9"/>
    <text x="540" y="175" font-family="Arial, sans-serif" font-size="10" fill="#2c3e50">Agua</text>
  </g>
  
  <!-- Turbina eólica -->
  <g transform="translate(150, 100)">
    <rect x="-2" y="0" width="4" height="150" fill="#bdc3c7"/>
    <g transform="rotate(45)">
      <ellipse cx="0" cy="-30" rx="3" ry="25" fill="#ecf0f1"/>
      <ellipse cx="0" cy="-30" rx="3" ry="25" fill="#ecf0f1" transform="rotate(120)"/>
      <ellipse cx="0" cy="-30" rx="3" ry="25" fill="#ecf0f1" transform="rotate(240)"/>
    </g>
    <circle cx="0" cy="0" r="5" fill="#34495e"/>
  </g>
  
  <!-- Árboles y vegetación -->
  <g fill="#27ae60">
    <!-- Árboles grandes -->
    <circle cx="100" cy="280" r="25"/>
    <rect x="95" y="280" width="10" height="40" fill="#8b4513"/>
    
    <circle cx="600" cy="290" r="30"/>
    <rect x="595" y="290" width="10" height="50" fill="#8b4513"/>
    
    <circle cx="700" cy="300" r="20"/>
    <rect x="697" y="300" width="8" height="35" fill="#8b4513"/>
    
    <!-- Arbustos -->
    <ellipse cx="200" cy="330" rx="15" ry="10"/>
    <ellipse cx="250" cy="335" rx="12" ry="8"/>
    <ellipse cx="550" cy="340" rx="18" ry="12"/>
  </g>
  
  <!-- Iconos de sostenibilidad -->
  <g>
    <!-- Reciclaje -->
    <g transform="translate(50, 50)">
      <circle cx="0" cy="0" r="25" fill="#2ecc71" opacity="0.8"/>
      <path d="M -10 -5 L 0 -15 L 10 -5 M 0 -15 L 0 5 M -5 0 L 5 0" stroke="#FFFFFF" stroke-width="3" fill="none"/>
      <path d="M -8 8 Q 0 15 8 8 Q 0 12 -8 8" fill="#FFFFFF"/>
    </g>
    
    <!-- Energía limpia -->
    <g transform="translate(750, 50)">
      <circle cx="0" cy="0" r="25" fill="#f39c12" opacity="0.8"/>
      <path d="M -8 -8 L 8 0 L -8 8 L -3 0 Z" fill="#FFFFFF"/>
    </g>
  </g>
  
  <!-- Texto principal -->
  <text x="400" y="40" text-anchor="middle" font-family="Arial, sans-serif" font-size="28" font-weight="bold" fill="#2c3e50">
    Desarrollo Sostenible
  </text>
  
  <!-- Etiquetas -->
  <g font-family="Arial, sans-serif" font-size="12" fill="#2c3e50">
    <text x="400" y="380" text-anchor="middle">Construcción Verde • Energía Renovable • Eficiencia Hídrica</text>
  </g>
  
  <!-- Indicadores de eficiencia -->
  <g>
    <rect x="20" y="350" width="100" height="30" fill="#FFFFFF" opacity="0.9" rx="5"/>
    <text x="70" y="365" text-anchor="middle" font-family="Arial, sans-serif" font-size="10" fill="#27ae60" font-weight="bold">CO₂ -50%</text>
    <text x="70" y="375" text-anchor="middle" font-family="Arial, sans-serif" font-size="8" fill="#2c3e50">Emisiones</text>
  </g>
</svg>