<svg xmlns="http://www.w3.org/2000/svg" width="800" height="400" viewBox="0 0 800 400">
  <defs>
    <linearGradient id="investmentGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#667eea;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#764ba2;stop-opacity:1" />
    </linearGradient>
    <linearGradient id="chartGradient" x1="0%" y1="100%" x2="0%" y2="0%">
      <stop offset="0%" style="stop-color:#4facfe;stop-opacity:0.8" />
      <stop offset="100%" style="stop-color:#00f2fe;stop-opacity:0.8" />
    </linearGradient>
  </defs>
  
  <!-- Fondo -->
  <rect width="800" height="400" fill="url(#investmentGradient)"/>
  
  <!-- Gráfico de crecimiento -->
  <g transform="translate(50, 100)">
    <!-- Ejes del gráfico -->
    <g stroke="#FFFFFF" stroke-width="2" fill="none">
      <line x1="0" y1="200" x2="300" y2="200"/>
      <line x1="0" y1="0" x2="0" y2="200"/>
    </g>
    
    <!-- Línea de crecimiento -->
    <path d="M 0 180 Q 50 160 100 140 Q 150 120 200 100 Q 250 80 300 60" 
          stroke="#f39c12" stroke-width="4" fill="none"/>
    
    <!-- Área bajo la curva -->
    <path d="M 0 180 Q 50 160 100 140 Q 150 120 200 100 Q 250 80 300 60 L 300 200 L 0 200 Z" 
          fill="url(#chartGradient)"/>
    
    <!-- Puntos de datos -->
    <g fill="#f39c12">
      <circle cx="0" cy="180" r="4"/>
      <circle cx="60" cy="150" r="4"/>
      <circle cx="120" cy="125" r="4"/>
      <circle cx="180" cy="105" r="4"/>
      <circle cx="240" cy="85" r="4"/>
      <circle cx="300" cy="60" r="4"/>
    </g>
    
    <!-- Etiquetas del eje X -->
    <g font-family="Arial, sans-serif" font-size="10" fill="#FFFFFF" text-anchor="middle">
      <text x="0" y="220">2020</text>
      <text x="60" y="220">2021</text>
      <text x="120" y="220">2022</text>
      <text x="180" y="220">2023</text>
      <text x="240" y="220">2024</text>
      <text x="300" y="220">2025</text>
    </g>
    
    <!-- Etiquetas del eje Y -->
    <g font-family="Arial, sans-serif" font-size="10" fill="#FFFFFF" text-anchor="end">
      <text x="-10" y="185">S/ 100K</text>
      <text x="-10" y="155">S/ 150K</text>
      <text x="-10" y="125">S/ 200K</text>
      <text x="-10" y="95">S/ 250K</text>
      <text x="-10" y="65">S/ 300K</text>
    </g>
  </g>
  
  <!-- Calculadora de ROI -->
  <g transform="translate(450, 120)">
    <rect x="0" y="0" width="200" height="150" fill="#2c3e50" rx="10" opacity="0.9"/>
    
    <!-- Pantalla -->
    <rect x="15" y="15" width="170" height="40" fill="#27ae60" rx="5"/>
    <text x="100" y="38" text-anchor="middle" font-family="Arial, sans-serif" font-size="14" fill="#FFFFFF" font-weight="bold">ROI: +25%</text>
    
    <!-- Información de inversión -->
    <g font-family="Arial, sans-serif" font-size="11" fill="#FFFFFF">
      <text x="20" y="75">Inversión inicial:</text>
      <text x="150" y="75" text-anchor="end" font-weight="bold">S/ 200,000</text>
      
      <text x="20" y="95">Valor actual:</text>
      <text x="150" y="95" text-anchor="end" font-weight="bold">S/ 250,000</text>
      
      <text x="20" y="115">Ganancia:</text>
      <text x="150" y="115" text-anchor="end" font-weight="bold" fill="#27ae60">S/ 50,000</text>
      
      <text x="20" y="135">Tiempo:</text>
      <text x="150" y="135" text-anchor="end" font-weight="bold">24 meses</text>
    </g>
  </g>
  
  <!-- Iconos de estrategias -->
  <g>
    <!-- Diversificación -->
    <g transform="translate(100, 50)">
      <circle cx="0" cy="0" r="20" fill="#e74c3c" opacity="0.8"/>
      <g fill="#FFFFFF">
        <rect x="-8" y="-8" width="6" height="6"/>
        <rect x="2" y="-8" width="6" height="6"/>
        <rect x="-8" y="2" width="6" height="6"/>
        <rect x="2" y="2" width="6" height="6"/>
      </g>
      <text x="0" y="35" text-anchor="middle" font-family="Arial, sans-serif" font-size="10" fill="#FFFFFF">Diversificación</text>
    </g>
    
    <!-- Análisis -->
    <g transform="translate(250, 50)">
      <circle cx="0" cy="0" r="20" fill="#3498db" opacity="0.8"/>
      <g stroke="#FFFFFF" stroke-width="2" fill="none">
        <circle cx="0" cy="0" r="8"/>
        <line x1="6" y1="6" x2="12" y2="12"/>
      </g>
      <text x="0" y="35" text-anchor="middle" font-family="Arial, sans-serif" font-size="10" fill="#FFFFFF">Análisis</text>
    </g>
    
    <!-- Timing -->
    <g transform="translate(550, 50)">
      <circle cx="0" cy="0" r="20" fill="#27ae60" opacity="0.8"/>
      <g stroke="#FFFFFF" stroke-width="2" fill="none">
        <circle cx="0" cy="0" r="8"/>
        <line x1="0" y1="0" x2="0" y2="-5"/>
        <line x1="0" y1="0" x2="4" y2="3"/>
      </g>
      <text x="0" y="35" text-anchor="middle" font-family="Arial, sans-serif" font-size="10" fill="#FFFFFF">Timing</text>
    </g>
    
    <!-- Ubicación -->
    <g transform="translate(700, 50)">
      <circle cx="0" cy="0" r="20" fill="#f39c12" opacity="0.8"/>
      <path d="M 0 -8 Q -6 -2 0 8 Q 6 -2 0 -8 Z" fill="#FFFFFF"/>
      <circle cx="0" cy="-2" r="3" fill="#f39c12"/>
      <text x="0" y="35" text-anchor="middle" font-family="Arial, sans-serif" font-size="10" fill="#FFFFFF">Ubicación</text>
    </g>
  </g>
  
  <!-- Edificios de inversión -->
  <g transform="translate(450, 280)">
    <!-- Edificio 1 -->
    <rect x="0" y="30" width="30" height="70" fill="#34495e"/>
    <rect x="5" y="40" width="5" height="5" fill="#f39c12"/>
    <rect x="15" y="40" width="5" height="5" fill="#f39c12"/>
    <rect x="5" y="55" width="5" height="5" fill="#f39c12"/>
    <rect x="20" y="55" width="5" height="5" fill="#f39c12"/>
    
    <!-- Edificio 2 -->
    <rect x="40" y="20" width="35" height="80" fill="#2c3e50"/>
    <rect x="45" y="30" width="5" height="5" fill="#f39c12"/>
    <rect x="55" y="30" width="5" height="5" fill="#f39c12"/>
    <rect x="65" y="30" width="5" height="5" fill="#f39c12"/>
    <rect x="45" y="45" width="5" height="5" fill="#f39c12"/>
    <rect x="65" y="45" width="5" height="5" fill="#f39c12"/>
    
    <!-- Edificio 3 -->
    <rect x="85" y="35" width="25" height="65" fill="#34495e"/>
    <rect x="90" y="45" width="4" height="4" fill="#f39c12"/>
    <rect x="100" y="45" width="4" height="4" fill="#f39c12"/>
    <rect x="90" y="60" width="4" height="4" fill="#f39c12"/>
    <rect x="100" y="60" width="4" height="4" fill="#f39c12"/>
  </g>
  
  <!-- Título -->
  <text x="400" y="30" text-anchor="middle" font-family="Arial, sans-serif" font-size="28" font-weight="bold" fill="#FFFFFF">
    Inversión Inteligente
  </text>
  
  <!-- Subtítulo -->
  <text x="400" y="380" text-anchor="middle" font-family="Arial, sans-serif" font-size="14" fill="#FFFFFF">
    Estrategias • Análisis • Resultados
  </text>
</svg>